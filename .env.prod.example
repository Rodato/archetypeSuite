# Copia a .env.prod en el VPS y rellena con valores reales. NO se commitea.
#   cp .env.prod.example .env.prod && nano .env.prod

# Clave de OpenRouter (la misma que usas en local).
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# La URL pública la da el Cloudflare Tunnel (https://xxxx.trycloudflare.com) — cambia
# en cada reinicio del túnel. El frontend usa base relativa (mismo origen), así que
# NO hay dominio que configurar aquí. El acceso lo protege el basic auth del Caddyfile.
