# Backend: FastAPI wrapping the LangGraph archetype pipeline.
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System deps for scientific Python wheels are already in the slim image for these versions.
COPY requirements.txt ./
RUN pip install --upgrade pip && pip install -r requirements.txt

# App code (pipeline + API + sample data)
COPY src ./src
COPY api ./api
COPY sample_data ./sample_data

# Persisted runs ("Mis análisis"); mount a volume here to keep history across restarts.
ENV ARCHETYPE_DATA_DIR=/data
RUN mkdir -p /data

EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
