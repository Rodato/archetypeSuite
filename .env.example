# OpenRouter API key — obtén una en https://openrouter.ai/keys
# Requerida para que el pipeline pueda invocar los modelos LLM (Claude, Grok).
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Opcionales — descomenta y ajusta solo si quieres sobreescribir defaults.
# LLM_MODEL=anthropic/claude-sonnet-4.5
# LLM_NARRATIVE_MODEL=x-ai/grok-4.1-fast
# LLM_TEMPERATURE=0.0
# LLM_REQUEST_TIMEOUT=60
# MAX_REFINEMENT_ITERATIONS=2
# K_OPTIMIZER_MAX=10
